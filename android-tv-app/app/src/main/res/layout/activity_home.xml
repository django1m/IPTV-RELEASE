<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.browse.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Tab Bar -->
        <LinearLayout
            android:id="@+id/tab_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/tab_background"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical">

            <!-- App Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="32dp" />

            <!-- Tab Buttons -->
            <Button
                android:id="@+id/tab_live"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="TV en direct"
                android:textColor="@color/tab_text_color"
                android:textSize="15sp"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:background="@drawable/tab_button_background"
                android:paddingHorizontal="20dp"
                android:layout_marginEnd="4dp"
                android:focusable="true"
                android:nextFocusDown="@id/content_fragment" />

            <Button
                android:id="@+id/tab_movies"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Films"
                android:textColor="@color/tab_text_color"
                android:textSize="15sp"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:background="@drawable/tab_button_background"
                android:paddingHorizontal="20dp"
                android:layout_marginEnd="4dp"
                android:focusable="true"
                android:nextFocusDown="@id/content_fragment" />

            <Button
                android:id="@+id/tab_series"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Séries"
                android:textColor="@color/tab_text_color"
                android:textSize="15sp"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:background="@drawable/tab_button_background"
                android:paddingHorizontal="20dp"
                android:layout_marginEnd="4dp"
                android:focusable="true"
                android:nextFocusDown="@id/content_fragment" />

            <Button
                android:id="@+id/tab_favorites"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Favoris"
                android:textColor="@color/tab_text_color"
                android:textSize="15sp"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:background="@drawable/tab_button_background"
                android:paddingHorizontal="20dp"
                android:layout_marginEnd="4dp"
                android:focusable="true"
                android:nextFocusDown="@id/content_fragment" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/tab_guide"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_guide"
                android:background="@drawable/tab_button_background"
                android:scaleType="center"
                android:layout_marginEnd="8dp"
                android:focusable="true"
                android:nextFocusDown="@id/content_fragment"
                android:contentDescription="@string/tab_guide" />

            <ImageButton
                android:id="@+id/tab_search"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_search"
                android:background="@drawable/tab_button_background"
                android:scaleType="center"
                android:layout_marginEnd="8dp"
                android:focusable="true"
                android:nextFocusDown="@id/content_fragment"
                android:contentDescription="Rechercher" />

            <ImageButton
                android:id="@+id/tab_settings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_settings"
                android:background="@drawable/tab_button_background"
                android:scaleType="center"
                android:focusable="true"
                android:nextFocusDown="@id/content_fragment"
                android:contentDescription="Paramètres" />

        </LinearLayout>

        <!-- Divider line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AFFFFFF" />

        <!-- Content Fragment Container -->
        <FrameLayout
            android:id="@+id/content_fragment"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/grid_background" />

    </LinearLayout>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:id="@+id/loading_progress"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/primary" />

            <TextView
                android:id="@+id/loading_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Chargement..."
                android:textColor="@color/text_primary"
                android:textSize="18sp" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
