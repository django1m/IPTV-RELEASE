<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top toolbar -->
        <LinearLayout
            android:id="@+id/epg_toolbar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@color/tab_background"
            android:paddingHorizontal="24dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/epg_title"
                android:textColor="@color/primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="24dp" />

            <!-- Selected category label -->
            <TextView
                android:id="@+id/selected_category_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/epg_all_categories"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:fontFamily="sans-serif" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btn_jump_now"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/epg_jump_to_now"
                android:textColor="@color/background"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:background="@color/primary"
                android:paddingHorizontal="16dp"
                android:focusable="true" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AFFFFFF" />

        <!-- Main content: Category sidebar + EPG Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Category sidebar -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/category_list"
                android:layout_width="200dp"
                android:layout_height="match_parent"
                android:background="#0D1117"
                android:paddingVertical="4dp"
                android:clipToPadding="false"
                android:nextFocusRight="@id/epg_view" />

            <!-- Vertical divider -->
            <View
                android:id="@+id/category_divider"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#1AFFFFFF" />

            <!-- EPG Grid View -->
            <com.iptvplayer.tv.ui.epg.EpgView
                android:id="@+id/epg_view"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:focusable="true"
                android:nextFocusLeft="@id/category_list" />

        </LinearLayout>

        <!-- Info panel at bottom -->
        <LinearLayout
            android:id="@+id/info_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:orientation="horizontal"
            android:background="#E6111827"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"
            android:gravity="center_vertical">

            <!-- Channel logo -->
            <ImageView
                android:id="@+id/info_channel_logo"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:scaleType="centerCrop"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/info_channel_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/info_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/info_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/info_archive_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/epg_archive_available"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:background="@drawable/bg_rounded_dark"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:layout_marginStart="12dp"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <!-- Description on the right side -->
            <TextView
                android:id="@+id/info_description"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:maxLines="3"
                android:ellipsize="end"
                android:layout_marginStart="24dp" />

            <!-- Channel preview player -->
            <FrameLayout
                android:id="@+id/preview_container"
                android:layout_width="200dp"
                android:layout_height="112dp"
                android:layout_marginStart="16dp"
                android:background="#FF000000"
                android:visibility="gone">

                <androidx.media3.ui.PlayerView
                    android:id="@+id/preview_player_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:use_controller="false"
                    app:surface_type="texture_view"
                    app:resize_mode="fill"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />

                <!-- Thin amber border -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/preview_border" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Loading overlay -->
    <FrameLayout
        android:id="@+id/epg_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/epg_loading"
                android:textColor="@color/text_primary"
                android:textSize="18sp" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
