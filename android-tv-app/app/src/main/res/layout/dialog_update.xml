<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="560dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FF1E293B"
    android:padding="36dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/update_available_title"
        android:textColor="#FFFFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/update_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FF818CF8"
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/update_notes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FF9CA3AF"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginBottom="28dp"
        android:maxLines="6"
        android:ellipsize="end" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_update_later"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="@string/update_later"
            android:textColor="#FF9CA3AF"
            android:textSize="16sp"
            android:background="@drawable/btn_update_secondary"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginEnd="16dp"
            android:focusable="true"
            android:focusableInTouchMode="true" />

        <Button
            android:id="@+id/btn_update_now"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:minWidth="200dp"
            android:text="@string/update_now"
            android:textColor="#FF111827"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/btn_update_primary"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:focusable="true"
            android:focusableInTouchMode="true" />

    </LinearLayout>
</LinearLayout>
