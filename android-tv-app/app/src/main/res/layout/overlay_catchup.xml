<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/catchup_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="650dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_rounded_dark"
        android:orientation="vertical"
        android:padding="24dp"
        android:maxHeight="500dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/catchup_title"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/catchup_channel_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColor="@color/text_muted"
            android:textSize="14sp" />

        <!-- Loading -->
        <LinearLayout
            android:id="@+id/catchup_loading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="32dp"
                android:layout_height="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/loading"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Programs list -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fadingEdge="vertical"
            android:fadingEdgeLength="16dp"
            android:requiresFadingEdge="vertical">

            <LinearLayout
                android:id="@+id/catchup_program_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <!-- No EPG data message -->
        <TextView
            android:id="@+id/catchup_no_data"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:text="@string/catchup_no_data"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Back to live button -->
        <Button
            android:id="@+id/btn_back_to_live"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_rounded_dark"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="@string/catchup_back_to_live"
            android:textColor="@color/primary"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
