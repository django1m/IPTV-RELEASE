<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused + Selected -->
    <item android:state_focused="true" android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#33F59E0B" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
            <!-- Amber underline -->
            <item android:top="42dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/primary" />
                    <corners android:bottomLeftRadius="8dp" android:bottomRightRadius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Focused only -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#26FFFFFF" />
            <corners android:radius="8dp" />
            <stroke android:width="2dp" android:color="#40FFFFFF" />
        </shape>
    </item>
    <!-- Selected only (tab is active but focus is elsewhere) -->
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/transparent" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
            <!-- Amber underline indicator -->
            <item android:top="42dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/primary" />
                    <corners android:bottomLeftRadius="8dp" android:bottomRightRadius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Default -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
