<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state: indigo glow -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Gradient background -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#406366F1"
                        android:endColor="#1A6366F1"
                        android:angle="135" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <!-- Indigo border -->
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="2dp" android:color="#CC6366F1" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Default state -->
    <item>
        <layer-list>
            <!-- Gradient background -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#1E293B"
                        android:endColor="#162032"
                        android:angle="135" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <!-- Subtle border -->
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="#1AFFFFFF" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
